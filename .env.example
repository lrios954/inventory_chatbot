# Cars Inventory Project Environment
#
# Copy this file to `.env` for local development:
#
#   cp .env.example .env
#

# PostgreSQL container settings.
POSTGRES_DB=cars_inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Inventory API database URL.
# Use `db` as the host when running the API in Docker Compose.
# Use `localhost` as the host when running the API directly on your machine.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/cars_inventory

# Chatbot service settings.
INVENTORY_API_URL=http://api:8000
REQUEST_TIMEOUT_SECONDS=10.0
MAX_TOKENS=1200
TEMPERATURE=0.2

# Amazon Bedrock settings for the Strands agent.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS credentials.
# For temporary credentials, all three values are required.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Do not set AWS_PROFILE or AWS_BEARER_TOKEN_BEDROCK when using temporary
# session credentials in Docker Compose.
